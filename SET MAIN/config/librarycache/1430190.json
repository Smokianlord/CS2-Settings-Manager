880a.jpg","bAchieved":false,"rtUnlocked":0,"flAchieved":21.200000762939453,"flMinProgress":0,"flCurrentProgress":6,"flMaxProgress":25},{"strID":"ACH_029","strName":"Weekly Warrior","strDescription":"Survive a Weekly Operation","strImage":"https://shared.steamstatic.com/community_assets/images/apps/1430190/3eca7eb94380013b1a496c7d6cdc088bd2fd880a.jpg","bAchieved":false,"rtUnlocked":0,"flAchieved":20.200000762939453,"flMinProgress":0,"flCurrentProgress":0,"flMaxProgress":0}],"vecAchievedHidden":[],"nTotal":41,"nAchieved":17}}],["associations",{"version":2,"data":{"rgDevelopers":[{"strName":"Tripwire Interactive","strURL":"https://store.steampowered.com/developer/Tripwire"}],"rgPublishers":[{"strName":"Tripwire Interactive","strURL":"https://store.steampowered.com/publisher/Tripwire"}],"rgFranchises":[{"strName":"Killing Floor","strURL":"https://store.steampowered.com/curator/45208944"}]}}],["descriptions",{"version":1,"data":{"strFullDescription":"[p][imgvid poster.avif=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/8b3854ae0d2bb086b9a2c9cfb5bb6079.poster.avif?t=1774531201\" webm=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/8b3854ae0d2bb086b9a2c9cfb5bb6079.webm?t=1774531201\" width=\"616\" height=\"400\"][/imgvid][/p][p]It’s 2091. Join up with Nightfall, the last line of defense against megacorp Horzine’s inhuman army of monstrous zeds. The future is in your hands… if you can survive long enough to reach it.[/p][p][/p][p][i][b]Killing Floor 3[/b][/i] is the next installment in the legendary action/horror series. This intense FPS puts you in the boots of a Nightfall specialist joining forces with up to five teammates to battle waves of Zeds, earn dosh, unlock skills, and build the ultimate arsenal.[/p][p][imgvid poster.avif=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/4ac4c191fc7629a5b59e7bd9b60f1498.poster.avif?t=1774531201\" webm=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/4ac4c191fc7629a5b59e7bd9b60f1498.webm?t=1774531201\" webp=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/4ac4c191fc7629a5b59e7bd9b60f1498.webp?t=1774531201\" width=\"616\" height=\"393\"][/imgvid][/p][p][img width=\"332\" height=\"34\"]https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/9ce23beedb53e6fb97452b50870dc142.webp?t=1774531201[/img][/p][p]Assemble the ultimate zed extermination squad for frenzied 6-player co-op. You can also brave the battlefield alone in tense single-player mode.[/p][p][imgvid poster.avif=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/5c819ad059c902687d4c869fcc546771.poster.avif?t=1774531201\" webm=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/5c819ad059c902687d4c869fcc546771.webm?t=1774531201\" webp=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/5c819ad059c902687d4c869fcc546771.webp?t=1774531201\" width=\"616\" height=\"393\"][/imgvid][/p][h2][img width=\"418\" height=\"34\"]https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/14151138f18048bb689aa73f3d77086d.webp?t=1774531201[/img][/h2][p]Brace yourself for the most lethal zeds yet. Every enemy has been redesigned and retuned with smarter AI; making them faster, deadlier, and more strategic than ever.[/p][p][imgvid poster.avif=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/8255d2e87e44246bce491f27def4b2f4.poster.avif?t=1774531201\" webm=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/8255d2e87e44246bce491f27def4b2f4.webm?t=1774531201\" webp=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/8255d2e87e44246bce491f27def4b2f4.webp?t=1774531201\" width=\"616\" height=\"393\"][/imgvid][/p][h2][img width=\"385\" height=\"34\"]https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/f2d8b98c98fbe3f598fcb7b3ad37122c.webp?t=1774531201[/img][/h2][p]From flamethrowers to shotguns to katanas, you’ll have an expansive arsenal at your disposal. Customize your own unique brand of bloodletting with hundreds of mods, gadgets, and skills to choose from.[/p][p][imgvid poster.avif=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/628d61201f14036231fed5fbad2f2b4b.poster.avif?t=1774531201\" webm=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/628d61201f14036231fed5fbad2f2b4b.webm?t=1774531201\" webp=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/628d61201f14036231fed5fbad2f2b4b.webp?t=1774531201\" width=\"616\" height=\"393\"][/imgvid][/p][h2][img width=\"582\" height=\"34\"]https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/6805e1a25f2c33d4a9499d5c61bd4142.webp?t=1774531201[/img][/h2][p]Drop into a variety of treacherous hot zones where you’ll have to contain the further spread of the Outbreak. Thankfully, you can use the environment to your advantage by activating turrets, fans, and other devastating traps.[/p][p][img poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/c19fbbce14925124f17ea182fcc0aeb8.poster.avif?t=1774531201\" width=\"616\" height=\"393\"]https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/c19fbbce14925124f17ea182fcc0aeb8.webp?t=1774531201[/img][/p][h2][img width=\"278\" height=\"34\"]https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/1430190/extras/993f4351e926330cfd3ea033d74735f2.webp?t=1774531201[/img][/h2][p]Our M.E.A.T. System returns to deliver even more realistic carnage. Featuring additional points of dismemberment and persistent blood, the game responds to your attacks with gruesome authenticity.[/p][p] [/p][p][/p]","strSnippet":"